{
  "manifest_version": 3,
  "name": "Mono Tab",
  "version": "1.0.0",
  "description": "A minimalist and efficient tag management extension program",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon128.png",
    "32": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "My Speed Dial"
  }
}